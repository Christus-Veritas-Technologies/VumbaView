# Base URL of apps/server, used by lib/api.ts for every backend request this
# app makes — there is no other place in the codebase that builds or hardcodes
# a server URL. Must be prefixed EXPO_PUBLIC_ to be inlined into the built app
# (Expo only exposes EXPO_PUBLIC_* vars to client code). Defaults to
# http://localhost:3000 if unset.
#
# For a physical device/emulator talking to a server on your own machine, use
# your machine's LAN IP, not localhost (e.g. http://192.168.1.20:3000) —
# localhost on the device resolves to the device itself, not your computer.
#
# For EAS builds (preview/production), this needs to be set at build time —
# either via a committed apps/reception/.env, or per-profile "env" blocks in
# eas.json, or EAS's own dashboard environment variables — otherwise the
# built app silently falls back to localhost, which is unreachable from a
# real device.
EXPO_PUBLIC_API_URL=http://localhost:3000
