# Postgres connection string the app uses at runtime, e.g.
# postgresql://user:password@localhost:5432/vva_reception
# On Prisma Postgres this is the *pooled* string (host: pooled.db.prisma.io).
DATABASE_URL=

# Connection string the Prisma CLI uses for migrate/introspect/Studio
# (see prisma.config.ts). On a plain local Postgres this is the same value as
# DATABASE_URL. On Prisma Postgres it must be the *direct* string (host:
# db.prisma.io) — the pooled host doesn't support what migrations need.
DIRECT_URL=

# Long random string used to sign staff session JWTs
JWT_SECRET=

# Origin allowed to call this API. apps/web (the marketing site) calls this
# API directly from the browser to submit admissions inquiries, so set this
# to apps/web's origin. The Expo reception app is native-only (no web
# target), so it isn't subject to browser CORS and doesn't need to be listed.
CORS_ORIGIN=http://localhost:3001

PORT=3000
NODE_ENV=development

# WhatsApp notifications (see src/lib/whatsapp.ts) — both optional; the app
# runs fine with neither set, it just won't send anything.

# Admin's WhatsApp number to notify on new payments/admissions inquiries, in
# international format, digits only or with +/spaces/dashes (e.g.
# +263771234567 — they're stripped down to digits before sending).
ADMIN_WHATSAPP_NUMBER=

# Optional override for the Chromium/Chrome binary puppeteer should drive.
# Leave unset to use whatever puppeteer downloaded for itself (its own
# postinstall step, both locally and in the Docker image) — that's correct in
# almost every case, since that build is version-matched to the installed
# puppeteer. Only set this to point at a different/system Chromium instead.
CHROMIUM_URL=
