generator client {
  provider = "prisma-client-js"
}

// Prisma 7: the connection URL no longer lives here — it's configured in
// prisma.config.ts (and read by the app itself via @vva/env's DATABASE_URL).
datasource db {
  provider = "postgresql"
}

enum StaffRole {
  ADMIN
  RECEPTIONIST
}

enum AcademicLevel {
  FORM_1
  FORM_2
  FORM_3
  FORM_4
  FORM_5
  FORM_6
}

enum EnrollmentStatus {
  ACTIVE
  WITHDRAWN
  GRADUATED
}

enum PaymentCategory {
  FEES
  UNIFORMS
  CUSTOM
}

enum InquiryStatus {
  NEW
  CONTACTED
  ENROLLED
  DECLINED
}

/// A staff login. Accounts are created by an Admin from inside the app — no public signup.
model Staff {
  id           String    @id @default(cuid())
  username     String    @unique
  passwordHash String
  role         StaffRole
  active       Boolean   @default(true)
  createdAt    DateTime  @default(now())

  studentsCreated  Student[] @relation("StudentCreatedBy")
  paymentsRecorded Payment[] @relation("PaymentRecordedBy")

  @@map("staff")
}

/// The live, editable fee schedule. One row per academic level, defaults to $0.
/// Edited any time from Admin Settings; only takes effect once snapshotted into
/// a new Term via "Start New Term" (see TermLevelFee).
model LevelFeeSetting {
  level     AcademicLevel @id
  amount    Decimal       @default(0) @db.Decimal(10, 2)
  updatedAt DateTime      @updatedAt

  @@map("level_fee_settings")
}

/// A school term. Created by the "Start New Term" admin action, which also
/// snapshots LevelFeeSetting into TermLevelFee so historical fee amounts
/// never change retroactively. Only one Term should have isCurrent = true.
model Term {
  id        String   @id @default(cuid())
  number    Int      @unique
  isCurrent Boolean  @default(false)
  startedAt DateTime @default(now())

  feeSnapshots TermLevelFee[]
  payments     Payment[]

  @@map("terms")
}

/// Frozen per-level fee amount for a specific term, copied from LevelFeeSetting
/// at the moment the term started.
model TermLevelFee {
  id     String        @id @default(cuid())
  level  AcademicLevel
  amount Decimal       @db.Decimal(10, 2)

  term   Term   @relation(fields: [termId], references: [id], onDelete: Cascade)
  termId String

  @@unique([termId, level])
  @@map("term_level_fees")
}

model Student {
  id          String           @id @default(cuid())
  admissionNo Int              @unique @default(autoincrement())
  fullName    String
  dateOfBirth DateTime?
  photoUrl    String?
  level       AcademicLevel
  status      EnrollmentStatus @default(ACTIVE)
  enrolledAt  DateTime         @default(now())

  guardianName    String?
  guardianPhone   String?
  guardianEmail   String?
  guardianAddress String?

  createdBy   Staff?  @relation("StudentCreatedBy", fields: [createdById], references: [id])
  createdById String?

  payments Payment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("students")
}

/// A logged payment. Only category = FEES decrements the student's term balance;
/// UNIFORMS/CUSTOM are record-keeping only. termId is resolved server-side at
/// write time (the term current at sync time), not client-side, so payments
/// synced after an offline term rollover land in the right term.
model Payment {
  id         String          @id @default(cuid())
  category   PaymentCategory
  amount     Decimal         @db.Decimal(10, 2)
  /// Optional cash discount applied at the time of payment. The student's
  /// balance is still credited the full `amount` (see lib/term.ts) — this
  /// only reduces how much of `amount` counts as cash actually collected,
  /// e.g. for the dashboard's "collected" total and payment reports.
  discount   Decimal         @default(0) @db.Decimal(10, 2)
  note       String?
  occurredAt DateTime        @default(now())

  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId String

  term   Term   @relation(fields: [termId], references: [id])
  termId String

  recordedBy   Staff  @relation("PaymentRecordedBy", fields: [recordedById], references: [id])
  recordedById String

  createdAt DateTime @default(now())

  @@map("payments")
}

/// A public admissions inquiry submitted from the marketing site's form (page
/// or navbar dialog) — no staff login required to create one. `status`
/// starts at NEW and is meant to be triaged from the reception/admin app once
/// an inquiries view is built there; no endpoint changes it yet. `type`
/// distinguishes a full application from a tour request — both are the same
/// top-of-funnel admissions pipeline, so they share this model/status flow
/// rather than splitting into a separate TourRequest model.
model Inquiry {
  id         String        @id @default(cuid())
  type       InquiryType   @default(APPLICATION)
  parentName String
  phone      String
  childName  String
  level      AcademicLevel
  message    String?
  status     InquiryStatus @default(NEW)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@map("inquiries")
}

enum InquiryType {
  APPLICATION
  TOUR_REQUEST
}
